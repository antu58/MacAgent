# Docker runtime
HOST_PORT=19090
MEMORY_TTL_SECONDS=600
FEISHU_SOCKET_ENABLED=0
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_OPEN_BASE_URL=
INTENT_TIMEOUT_SECONDS=30
EXECUTION_TIMEOUT_SECONDS=60
DEEP_TIMEOUT_SECONDS=120

# Proxy for image pull/build
ENABLE_PROXY=1
PROXY_URL=http://192.168.65.254:7897
HTTP_PROXY=http://192.168.65.254:7897
HTTPS_PROXY=http://192.168.65.254:7897
NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Classifier model (inside Docker should use host.docker.internal)
INTENT_MODEL_BASE_URL=http://host.docker.internal:18081/v1
INTENT_MODEL_NAME=mlx-community/Qwen3.5-0.8B-8bit
INTENT_MODEL_API_KEY=sk-local

# Execution model mapping
LOW_PRECISION_MODEL_BASE_URL=http://host.docker.internal:18081/v1
LOW_PRECISION_MODEL_NAME=mlx-community/Qwen3.5-0.8B-8bit
LOW_PRECISION_MODEL_API_KEY=sk-local

LOW_PRECISION_MULTIMODAL_MODEL_BASE_URL=http://host.docker.internal:18082/v1
LOW_PRECISION_MULTIMODAL_MODEL_NAME=mlx-community/Qwen3.5-4B-MLX-8bit
LOW_PRECISION_MULTIMODAL_MODEL_API_KEY=sk-local

HIGH_PRECISION_MULTIMODAL_MODEL_BASE_URL=
HIGH_PRECISION_MULTIMODAL_MODEL_NAME=
HIGH_PRECISION_MULTIMODAL_MODEL_API_KEY=

# Slow path deep model (Doubao OpenAI-compatible)
DEEP_MODEL_BASE_URL=https://api.newcoin.tech/v1
DEEP_MODEL_NAME=doubao-seed-1-6-251015
DEEP_MODEL_API_KEY=
DEEP_MODEL_INSECURE_SKIP_VERIFY=1
