#!/usr/bin/env bash

# Service defaults (override by exporting variables before running scripts).
export MLX_SERVICE_HOME="${MLX_SERVICE_HOME:-$HOME/.mlx-qwen35-9b}"
export HF_HOME="${HF_HOME:-$MLX_SERVICE_HOME/hf}"
export HUGGINGFACE_HUB_CACHE="${HUGGINGFACE_HUB_CACHE:-$HF_HOME/hub}"
export TRANSFORMERS_CACHE="${TRANSFORMERS_CACHE:-$HF_HOME/transformers}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$MLX_SERVICE_HOME/xdg-cache}"

export MODEL_ID="${MODEL_ID:-mlx-community/Qwen3.5-9B-8bit}"
export VENV_DIR="${VENV_DIR:-$MLX_SERVICE_HOME/venv}"
export HOST="${HOST:-0.0.0.0}"
export PORT="${PORT:-18083}"
export MAX_KV_SIZE="${MAX_KV_SIZE:-131072}"
export MAX_TOKENS="${MAX_TOKENS:-1024}"
export LOG_LEVEL="${LOG_LEVEL:-INFO}"
export TRUST_REMOTE_CODE="${TRUST_REMOTE_CODE:-1}"
